rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // El superadmin se reconoce por su correo EXACTO y VERIFICADO.
    // ⚠️ Nunca usar patrones tipo 'juanda.fonsecag@.*': cualquiera puede
    // registrarse con juanda.fonsecag@otrodominio.com (sin verificar el
    // correo) y el token pasaria el patron => superadmin regalado.
    // Para agregar otro superadmin: sumar aqui su correo real (de Google,
    // que llega con email_verified=true) y volver a publicar las reglas.
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'juanda.fonsecag@gmail.com';
    }

    match /artifacts/{appId} {

      // Sub-admin de colegio: tiene documento en admins/{uid}.
      function isSchoolAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/artifacts/$(appId)/admins/$(request.auth.uid));
      }
      function isAdmin() { return isSuperAdmin() || isSchoolAdmin(); }

      // Colegio asignado al sub-admin (su alcance). Los sub-admins solo
      // llegan a los usuarios y novedades de SU colegio.
      function adminSchool() {
        return get(/databases/$(database)/documents/artifacts/$(appId)/admins/$(request.auth.uid)).data.get('school', '');
      }

      // Regla dura multi-tenant: el tag de colegio NUNCA se autodeclara.
      // Un usuario solo puede escribirse un colegio si presenta un codigo de
      // invitacion ACTIVO de ese colegio (campo codigoInvitacion del perfil).
      function codigoValido(school, codigo) {
        return codigo is string && codigo != ''
          && exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/codigos/$(codigo))
          && get(/databases/$(database)/documents/artifacts/$(appId)/public/data/codigos/$(codigo)).data.get('colegioId', '') == school
          && get(/databases/$(database)/documents/artifacts/$(appId)/public/data/codigos/$(codigo)).data.get('activo', false) == true;
      }
      // En CREACION propia: sin school, red general (LCP mientras sea el
      // unico colegio), o school respaldado por codigo valido.
      function schoolValidaAlCrear() {
        let s = request.resource.data.get('school', '');
        return s == '' || s == 'LCP'
          || codigoValido(s, request.resource.data.get('codigoInvitacion', ''));
      }
      // En ACTUALIZACION propia: school sin cambio, completar el default LCP
      // cuando faltaba, o cambiarse con codigo valido del colegio destino.
      function schoolValidaAlActualizar() {
        let nueva = request.resource.data.get('school', '');
        let vieja = resource.data.get('school', '');
        return nueva == vieja
          || (vieja == '' && nueva == 'LCP')
          || codigoValido(nueva, request.resource.data.get('codigoInvitacion', ''));
      }

      // Directorio de egresados: lectura PUBLICA porque el modo invitado
      // explora el directorio sin login (browseAsGuest no autentica).
      // Trade-off: los datos de perfil quedan legibles sin login; la
      // alternativa mas protectora es Anonymous Auth + lectura autenticada.
      match /public/data/alumni/{userId} {
        allow read: if true;
        allow create: if request.auth != null && (
          isSuperAdmin()
          || (isSchoolAdmin() && request.resource.data.get('school', '') == adminSchool())
          || (request.auth.uid == userId && schoolValidaAlCrear())
        );
        allow update: if request.auth != null && (
          isSuperAdmin()
          || (isSchoolAdmin()
              && resource.data.get('school', '') == adminSchool()
              && request.resource.data.get('school', '') == adminSchool())
          || (request.auth.uid == userId && schoolValidaAlActualizar())
        );
        allow delete: if isSuperAdmin()
          || (isSchoolAdmin() && resource.data.get('school', '') == adminSchool());

        // Hitos de la trayectoria: visibles tambien en modo invitado
        // (el slide panel del directorio carga la ruta del egresado).
        // Los sub-admins solo tocan rutas de egresados de su colegio.
        match /hitos/{hitoId} {
          allow read: if true;
          allow write: if request.auth != null && (
            request.auth.uid == userId
            || isSuperAdmin()
            || (isSchoolAdmin()
                && get(/databases/$(database)/documents/artifacts/$(appId)/public/data/alumni/$(userId)).data.get('school', '') == adminSchool())
          );
        }

        // Resultados de práctica de idiomas (TOEFL/DELF). A diferencia de los
        // hitos, NO son públicos: son datos personales del estudiante. Los lee
        // el propio dueño y los admins de su colegio. Cada intento lo crea SOLO
        // el dueño (la práctica corre en su sesión) y es inmutable; borrarlo
        // puede el dueño o un admin de su colegio.
        match /examResults/{resultId} {
          function ownerSchool() {
            return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/alumni/$(userId)).data.get('school', '');
          }
          allow read: if request.auth != null && (
            request.auth.uid == userId
            || isSuperAdmin()
            || (isSchoolAdmin() && ownerSchool() == adminSchool())
          );
          allow create: if request.auth != null && request.auth.uid == userId;
          allow update: if false;
          allow delete: if request.auth != null && (
            request.auth.uid == userId
            || isSuperAdmin()
            || (isSchoolAdmin() && ownerSchool() == adminSchool())
          );
        }
      }

      // Colegios (multi-tenant): nombre, modulos pagados (toefl/delf), etc.
      // Lectura publica: el registro muestra el nombre del colegio del codigo
      // y la pagina de preparacion consulta los modulos sin exigir sesion.
      match /public/data/colegios/{colegioId} {
        allow read: if true;
        allow write: if isSuperAdmin();
      }

      // Codigos de invitacion: GET publico (validar un codigo exige conocerlo,
      // el id ES el codigo), pero LIST solo superadmin para que nadie pueda
      // enumerar los codigos vigentes.
      match /public/data/codigos/{codigo} {
        allow get: if true;
        allow list: if isSuperAdmin();
        allow write: if isSuperAdmin();
      }

      // Organizaciones normalizadas (autocompletar del onboarding/perfil).
      // Solo se usan estando autenticado; cualquier autenticado aporta,
      // solo admin depura/borra.
      match /public/data/organizaciones/{orgId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if isAdmin();
      }

      // Noticias: lectura publica; el superadmin publica a cualquier
      // audiencia y el sub-admin SOLO a su colegio (campo audiencia).
      match /public/data/news/{newsId} {
        allow read: if true;
        allow create, update: if isSuperAdmin()
          || (isSchoolAdmin() && request.resource.data.get('audiencia', '') == adminSchool());
        allow delete: if isSuperAdmin()
          || (isSchoolAdmin() && resource.data.get('audiencia', '') == adminSchool());
      }

      // Contacto de terceros (empresas, aliados, contacto general) desde la
      // landing. CREATE es PUBLICO (quien escribe no tiene cuenta), pero con
      // FORMA ESTRICTA como barrera anti-spam basica: campos permitidos,
      // tipos, longitudes y estado inicial fijo. Leerlos/gestionarlos es SOLO
      // del superadmin: son leads comerciales de la red (empresas, aliados),
      // no tienen colegio y nada tienen que ver con el alcance de un
      // sub-admin. Antes decia isAdmin() => cualquier sub-admin los leia.
      // Si aparece spam real, el siguiente paso es un captcha (Turnstile).
      match /public/data/contactos/{contactoId} {
        function contactoValido() {
          let d = request.resource.data;
          return d.keys().hasOnly(['tipo','nombre','organizacion','email','telefono','mensaje','estado','createdAt','userAgent'])
            && d.tipo in ['empresa','aliado','general']
            && d.nombre is string && d.nombre.size() >= 2 && d.nombre.size() <= 120
            && d.email is string && d.email.size() >= 5 && d.email.size() <= 160 && d.email.matches('.+@.+[.].+')
            && d.mensaje is string && d.mensaje.size() >= 10 && d.mensaje.size() <= 3000
            && d.organizacion is string && d.organizacion.size() <= 160
            && d.telefono is string && d.telefono.size() <= 40
            && d.estado == 'nuevo'
            && d.createdAt == request.time;
        }
        allow create: if contactoValido();
        allow read, update, delete: if isSuperAdmin();
      }

      // Usuarios de login (username -> authEmail/uid). Lectura publica
      // porque se resuelve ANTES de autenticar. Un usuario reserva su
      // propio username; el superadmin reserva el de un sub-admin nuevo
      // (lo crea con una app de auth secundaria, escribiendo un uid ajeno).
      // Antes decia isAdmin(): un sub-admin podia apuntar el username de
      // cualquiera a su propio uid (secuestro de login) o borrarlo.
      match /usernames/{username} {
        allow read: if true;
        allow create, update: if request.auth != null
          && (request.resource.data.uid == request.auth.uid || isSuperAdmin());
        allow delete: if isSuperAdmin();
      }

      // Administradores de colegio: solo el superadmin asigna/revoca.
      // Lectura: cada quien SU documento (loadAdminRole lo consulta para
      // saber su rol) y el superadmin la lista completa. Con isAdmin() un
      // sub-admin podia listar a los demas sub-admins y sus colegios.
      match /admins/{userId} {
        allow get: if request.auth != null
          && (request.auth.uid == userId || isSuperAdmin());
        allow list: if isSuperAdmin();
        allow write: if isSuperAdmin();
      }

      // Chats: cada usuario tiene SU copia del chat; el par (peer) puede
      // escribir en la copia del otro al enviar mensaje.
      match /users/{userId}/chats/{chatId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && (request.auth.uid == userId || request.resource.data.peerId == request.auth.uid);
        match /messages/{messageId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null
            && request.resource.data.senderId == request.auth.uid;
        }
      }
    }
  }
}
